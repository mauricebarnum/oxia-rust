{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePaths": [
    "ext/oxia/**"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "automerge": false,
      "semanticCommits": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 0 * * 1"]
  },
  "enabledManagers": [
    "cargo",
    "github-actions"
  ]
}
